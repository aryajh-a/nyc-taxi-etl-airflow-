# Copy to .env and fill in real values. .env is gitignored.

# ---- GCP / BigQuery Sandbox ----
GCP_PROJECT_ID=your-gcp-project-id
BQ_DATASET_RAW=raw
BQ_DATASET_STAGING=staging
BQ_DATASET_MARTS=marts
BQ_DATASET_DQ=dq

# Service account JSON is mounted from ./secrets/bq-sa.json into containers.
# Download it from GCP console (IAM & Admin -> Service Accounts -> Keys -> Add Key -> JSON)
# and save as secrets/bq-sa.json. That path is gitignored.

# ---- API ----
API_KEY=dev-api-key-change-me

# ---- Airflow ----
AIRFLOW_SECRET_KEY=change-this-to-a-random-32-char-string
# Linux users only: set to your host UID so airflow logs are writable.
# AIRFLOW_UID=1000

# ---- Kafka / Redpanda ----
KAFKA_BOOTSTRAP_INTERNAL=redpanda:29092
KAFKA_TOPIC_RAW=consent.events.raw
KAFKA_TOPIC_DLQ=consent.events.dlq

# ---- Redis ----
REDIS_URL_LOCAL=redis://redis:6379

# ---- Upstash (production cache; leave blank for local) ----
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- Fly.io ----
# Set via `fly secrets set KEY=value`, not in this file.
